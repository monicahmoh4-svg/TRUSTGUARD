# ============================================
# TrustGuard AI - Environment Variables
# Copy this to .env.local for local dev
# Add all these to Vercel dashboard for prod
# ============================================

# --- REQUIRED ---
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Get from: https://etherscan.io/apis
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# Get from: https://dashboard.alchemy.com/
ALCHEMY_API_KEY=YOUR_ALCHEMY_KEY

# --- OPTIONAL (enables more chains) ---
# Get from: https://bscscan.com/apis
BSCSCAN_API_KEY=YOUR_BSCSCAN_KEY

# Get from: https://polygonscan.com/apis
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_KEY

# Your deployed URL (set after first Vercel deploy)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
